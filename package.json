{
  "name": "motchi",
  "version": "1.0.0",
  "description": "Motchi - Anime streaming home server",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch --exclude './data/**' --exclude './downloads/**' server/index.ts",
    "build": "vite build && tsc -p tsconfig.server.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx server/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "start": "node dist/server/index.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.1.0",
    "@tanstack/react-query": "^5.96.2",
    "better-sqlite3": "^12.8.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.4",
    "hls.js": "^1.6.15",
    "lucide-react": "^1.7.0",
    "node-fetch": "^3.3.2",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.6"
  }
}
