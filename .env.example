# Server port (default: 3001)
PORT=3001

# Comma-separated browser origins allowed to call the API directly.
# Leave unset in production when serving the frontend from the same origin.
# CORS_ORIGIN=http://localhost:3000

# Set to 1 to explicitly enable the Cloudflare tunnel
# ENABLE_TUNNEL=1

# Your tunnel domain (optional, used for log messages)
# TUNNEL_DOMAIN=motchi.example.com
